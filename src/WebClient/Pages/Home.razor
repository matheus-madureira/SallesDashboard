@page "/"
@using Microsoft.AspNetCore.SignalR.Client;
@using WebClient.Constants
@using WebClient.ViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<PageTitle>Dashboard</PageTitle>

<h1 class="text-4xl font-bold">Ol&aacute;, seja bem vindo</h1>

<p class="text-lg text-zinc-700">Acompanhe todas as suas vendas em tempo real.</p>

@if (_products.Count == 0)
{
    <Skeleton/>
}
else
{
    <DataTable Products="_products"/>
}

@code
{
    private HubConnection? _connection;
    private readonly List<ProductViewModel> _products = [];

    protected override async Task OnInitializedAsync()
    {
        var hubUrl = Configuration[ConfigurationKeys.SignalRHubUrl];
        if (string.IsNullOrWhiteSpace(hubUrl) || !Uri.TryCreate(hubUrl, UriKind.Absolute, out var hubUri))
        {
            throw new InvalidOperationException("A configuracao SignalR:HubUrl e obrigatoria e deve ser uma URL absoluta.");
        }

        _connection = new HubConnectionBuilder()
            .WithUrl(hubUri.ToString())
            .WithAutomaticReconnect()
            .Build();

        _connection.On<ProductViewModel>(
            Events.receiveProducts,
            product =>
            {
                _products.Add(product);
                InvokeAsync(StateHasChanged);
            });

        await _connection.StartAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_connection is not null)
        {
            await _connection.DisposeAsync();
        }
    }
}
